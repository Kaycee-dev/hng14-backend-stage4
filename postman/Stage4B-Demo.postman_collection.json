    {
      "name": "C – Profiles List / Search / Export",
      "item": [
        {
          "name": "GET /api/profiles (list with pagination)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('status success', () => pm.expect(body.status).to.eql('success'));",
                  "pm.test('page field', () => pm.expect(body.page).to.be.a('number'));",
                  "pm.test('limit field', () => pm.expect(body.limit).to.be.a('number'));",
                  "pm.test('total field', () => pm.expect(body.total).to.be.a('number').and.above(0));",
                  "pm.test('total_pages field', () => pm.expect(body.total_pages).to.be.a('number'));",
                  "pm.test('data array', () => pm.expect(body.data).to.be.an('array').and.not.empty);",
                  "pm.test('links object', () => pm.expect(body.links).to.be.an('object'));",
                  "pm.test('links.self present', () => pm.expect(body.links.self).to.be.a('string'));",
                  "",
                  "// Validate first profile shape",
                  "const p = body.data[0];",
                  "pm.test('profile has id', () => pm.expect(p.id).to.be.a('string'));",
                  "pm.test('profile has name', () => pm.expect(p.name).to.be.a('string'));",
                  "pm.test('profile has gender', () => pm.expect(p.gender).to.be.a('string'));",
                  "pm.test('profile has age', () => pm.expect(p.age).to.be.a('number'));",
                  "pm.test('profile has age_group', () => pm.expect(p.age_group).to.be.a('string'));",
                  "pm.test('profile has country_id', () => pm.expect(p.country_id).to.be.a('string'));",
                  "pm.test('profile has country_name', () => pm.expect(p.country_name).to.be.a('string'));",
                  "pm.test('profile has created_at UTC', () => pm.expect(p.created_at).to.match(/Z$/));",
                  "",
                  "// Save first profile_id for GET by ID test",
                  "pm.environment.set('profile_id', p.id);",
                  "console.log('Saved profile_id:', p.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {"key": "X-API-Version", "value": "{{apiVersion}}"},
              {"key": "Authorization", "value": "Bearer {{analystAccessToken}}"}
            ],
            "url": {
              "raw": "{{baseUrl}}/api/profiles?limit=5&page=1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profiles"],
              "query": [
                {"key": "limit", "value": "5"},
                {"key": "page", "value": "1"}
              ]
            }
          },
          "response": []
        },
        {
          "name": "GET /api/profiles/:id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('status success', () => pm.expect(body.status).to.eql('success'));",
                  "pm.test('data.id matches', () => pm.expect(body.data.id).to.eql(pm.environment.get('profile_id')));",
                  "pm.test('data has name', () => pm.expect(body.data.name).to.be.a('string'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {"key": "X-API-Version", "value": "{{apiVersion}}"},
              {"key": "Authorization", "value": "Bearer {{analystAccessToken}}"}
            ],
            "url": {
              "raw": "{{baseUrl}}/api/profiles/{{profile_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profiles", "{{profile_id}}"]
            },
            "description": "profile_id is saved by the list request above."
          },
          "response": []
        },
        {
          "name": "GET /api/profiles/search – NLS query",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('status success', () => pm.expect(body.status).to.eql('success'));",
                  "pm.test('data array', () => pm.expect(body.data).to.be.an('array'));",
                  "pm.test('total is number', () => pm.expect(body.total).to.be.a('number'));",
                  "// All returned profiles should be male from Nigeria",
                  "body.data.forEach(p => {",
                  "  pm.test('gender is male: ' + p.name, () => pm.expect(p.gender).to.eql('male'));",
                  "  pm.test('country is NG: ' + p.name, () => pm.expect(p.country_id).to.eql('NG'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {"key": "X-API-Version", "value": "{{apiVersion}}"},
              {"key": "Authorization", "value": "Bearer {{analystAccessToken}}"}
            ],
            "url": {
              "raw": "{{baseUrl}}/api/profiles/search?q=young males from Nigeria",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profiles", "search"],
              "query": [{"key": "q", "value": "young males from Nigeria"}]
            }
          },
          "response": []
        },
        {
          "name": "GET /api/profiles/search – OR clauses",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('success', () => pm.expect(body.status).to.eql('success'));",
                  "pm.test('data array', () => pm.expect(body.data).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {"key": "X-API-Version", "value": "{{apiVersion}}"},
              {"key": "Authorization", "value": "Bearer {{analystAccessToken}}"}
            ],
            "url": {
              "raw": "{{baseUrl}}/api/profiles/search?q=young males from Nigeria or senior females from Kenya",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profiles", "search"],
              "query": [{"key": "q", "value": "young males from Nigeria or senior females from Kenya"}]
            }
          },
          "response": []
        },
        {
          "name": "GET /api/profiles/export?format=csv",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const ct = pm.response.headers.get('Content-Type') || '';",
                  "pm.test('CSV Content-Type', () => pm.expect(ct).to.include('text/csv'));",
                  "const text = pm.response.text();",
                  "pm.test('CSV has header row', () => {",
                  "  const firstLine = text.split('\\n')[0];",
                  "  pm.expect(firstLine).to.include('id');",
                  "  pm.expect(firstLine).to.include('name');",
                  "  pm.expect(firstLine).to.include('gender');",
                  "  pm.expect(firstLine).to.include('age');",
                  "  pm.expect(firstLine).to.include('country_id');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {"key": "X-API-Version", "value": "{{apiVersion}}"},
              {"key": "Authorization", "value": "Bearer {{analystAccessToken}}"}
            ],
            "url": {
              "raw": "{{baseUrl}}/api/profiles/export?format=csv",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profiles", "export"],
              "query": [{"key": "format", "value": "csv"}]
            },
            "description": "The format=csv param is required. Returns Content-Disposition: attachment with a timestamped filename."
          },
          "response": []
        }
      ]
    },
    {
      "name": "D – Cache / Performance Demo",
      "item": [
        {
          "name": "Query 1 – cold (first hit)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set('_query_start', Date.now());"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const duration = Date.now() - pm.environment.get('_query_start');",
                  "pm.environment.set('cold_duration_ms', duration);",
                  "console.log('Cold query duration: ' + duration + 'ms');",
                  "// NOTE: timing is environment-dependent. Remote DB will be slower than in-process cache.",
                  "const body = pm.response.json();",
                  "pm.test('success', () => pm.expect(body.status).to.eql('success'));",
                  "pm.test('data array', () => pm.expect(body.data).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {"key": "X-API-Version", "value": "{{apiVersion}}"},
              {"key": "Authorization", "value": "Bearer {{analystAccessToken}}"}
            ],
            "url": {
              "raw": "{{baseUrl}}/api/profiles?gender=male&country_id=NG&min_age=18&max_age=30",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profiles"],
              "query": [
                {"key": "gender", "value": "male"},
                {"key": "country_id", "value": "NG"},
                {"key": "min_age", "value": "18"},
                {"key": "max_age", "value": "30"}
              ]
            }
          },
          "response": []
        },
        {
          "name": "Query 2 – warm (cache hit, same params)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set('_query_start', Date.now());"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const duration = Date.now() - pm.environment.get('_query_start');",
                  "pm.environment.set('warm_duration_ms', duration);",
                  "const cold = pm.environment.get('cold_duration_ms');",
                  "console.log('Warm (cached) duration: ' + duration + 'ms, cold was: ' + cold + 'ms');",
                  "// Cached response avoids a DB round-trip – typically faster.",
                  "// This check is advisory; real latency varies by network/DB.",
                  "pm.test('warm response is valid', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('success');",
                  "  pm.expect(body.data).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {"key": "X-API-Version", "value": "{{apiVersion}}"},
              {"key": "Authorization", "value": "Bearer {{analystAccessToken}}"}
            ],
            "url": {
              "raw": "{{baseUrl}}/api/profiles?gender=male&country_id=NG&min_age=18&max_age=30",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profiles"],
              "query": [
                {"key": "gender", "value": "male"},
                {"key": "country_id", "value": "NG"},
                {"key": "min_age", "value": "18"},
                {"key": "max_age", "value": "30"}
              ]
            }
          },
          "response": []
        },
        {
          "name": "Query 3 – canonical-equiv (reordered params, same cache key)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set('_query_start', Date.now());"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const duration = Date.now() - pm.environment.get('_query_start');",
                  "console.log('Canonical-equiv (cached) duration: ' + duration + 'ms');",
                  "// Params are in different order but normalize to the same cache key.",
                  "// total should equal Query 1 / 2.",
                  "const body = pm.response.json();",
                  "pm.test('same total as prior queries', () => {",
                  "  pm.expect(body.total).to.be.a('number');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {"key": "X-API-Version", "value": "{{apiVersion}}"},
              {"key": "Authorization", "value": "Bearer {{analystAccessToken}}"}
            ],
            "url": {
              "raw": "{{baseUrl}}/api/profiles?min_age=18&country_id=NG&max_age=30&gender=male",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profiles"],
              "query": [
                {"key": "min_age", "value": "18"},
                {"key": "country_id", "value": "NG"},
                {"key": "max_age", "value": "30"},
                {"key": "gender", "value": "male"}
              ]
            },
            "description": "Query params are in different order from Query 1/2. The normalizer canonicalizes them to the same cache key, so this also hits the cache."
          },
          "response": []
        }
      ]
    },
    {
